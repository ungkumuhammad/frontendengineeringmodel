# Supabase project URL (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (Project Settings -> API -> anon public)
# Safe to expose in the browser; RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (Project Settings -> API -> service_role)
# SERVER-ONLY. Never expose to the browser. Used only in server actions /
# route handlers for admin user management (create/delete auth users, etc.).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
